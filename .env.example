# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# Spotify Web API
SPOTIFY_CLIENT_ID="[CLIENT_ID]"
SPOTIFY_CLIENT_SECRET="[CLIENT_SECRET]"

# Vercel Cron Security
CRON_SECRET="[RANDOM_SECRET]"

# Stripe Payment (Spec §3.1 — category fees, NO ranking influence)
STRIPE_SECRET_KEY="sk_live_[SECRET_KEY]"
STRIPE_WEBHOOK_SECRET="whsec_[WEBHOOK_SECRET]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_[PUBLISHABLE_KEY]"
# Comma-separated list of allowed origins for Stripe checkout redirects
STRIPE_ALLOWED_ORIGINS="https://your-domain.com"
