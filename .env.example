# ─── Supabase PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ─── Supabase Auth ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# ─── NextAuth / Session ──────────────────────────────────────────────────────
NEXTAUTH_SECRET="[RANDOM_32_CHAR_SECRET]"

# ─── Spotify Web API ─────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID="[CLIENT_ID]"
SPOTIFY_CLIENT_SECRET="[CLIENT_SECRET]"

# ─── Vercel Cron Security ────────────────────────────────────────────────────
CRON_SECRET="[RANDOM_SECRET]"

# ─── Stripe Payment (Spec §3.1 — category fees, NO ranking influence) ────────
STRIPE_SECRET_KEY="sk_live_[SECRET_KEY]"
STRIPE_WEBHOOK_SECRET="whsec_[WEBHOOK_SECRET]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_[PUBLISHABLE_KEY]"
# Stripe subscription price IDs
STRIPE_PRICE_PRO="price_[PRO_PRICE_ID]"
STRIPE_PRICE_PRO_PLUS="price_[PRO_PLUS_PRICE_ID]"
# Comma-separated list of allowed origins for Stripe checkout redirects
STRIPE_ALLOWED_ORIGINS="https://your-domain.com"

# ─── Site URL (used for sitemap, RSS, emails, OG tags) ───────────────────────
NEXT_PUBLIC_SITE_URL="https://darktunes.com"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_[API_KEY]"
EMAIL_FROM="DarkTunes <noreply@darktunes.com>"

# ─── Discord Webhook ─────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/[WEBHOOK_ID]/[WEBHOOK_TOKEN]"

# ─── Upstash Redis (for distributed rate limiting in multi-instance deployments)
# Replace in-memory rate limiter with Upstash for multi-region Vercel deployments
UPSTASH_REDIS_REST_URL="https://[UPSTASH_ENDPOINT].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[UPSTASH_TOKEN]"

# ─── Error Monitoring (Sentry) ───────────────────────────────────────────────
SENTRY_DSN="https://[KEY]@[ORG].ingest.sentry.io/[PROJECT]"
NEXT_PUBLIC_SENTRY_DSN="https://[KEY]@[ORG].ingest.sentry.io/[PROJECT]"
