generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  name                  String
  displayName           String?
  role                  UserRole  @default(FAN)
  avatarUrl             String?
  credits               Int       @default(150)
  isDJVerified          Boolean   @default(false)
  kycDocumentUrl        String?
  kycStatus             KYCStatus @default(PENDING)
  kycReviewedBy         String?
  kycReviewedAt         DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  region                String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  band                 Band?              @relation("BandOwner")
  fanVotes             FanVote[]
  djBallots            DJBallot[]
  bandVotesGiven       BandVote[]         @relation("VoterBand")
  transparencyLogs     TransparencyLogEntry[]
  botDetectionReviews  BotDetectionAlert[] @relation("Reviewer")
  eventIntents         EventIntent[]
  labelMandatesAsLabel LabelBandMandate[] @relation("LabelMandate")
  djFeedbackGiven      DJFeedback[]       @relation("DJFeedbackGiver")
  djVerification       DJVerification?
  auditLogs            AuditLog[]

  @@map("users")
}

enum UserRole {
  FAN
  DJ
  BAND
  EDITOR
  ADMIN
  AR
  LABEL
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

model Band {
  id                      String            @id @default(uuid())
  name                    String
  slug                    String?           @unique
  genre                   Genre             @default(GOTH)
  genres                  String[]
  spotifyMonthlyListeners Int               @default(0)
  tier                    Tier              @default(MICRO)
  logoUrl                 String?
  coverArtUrl             String?
  imageUrl                String?
  spotifyUrl              String?
  spotifyUri              String?
  bandcampUrl             String?
  spotifyArtistId         String?
  country                 String?
  formedYear              Int?
  bio                     String?
  isVerified              Boolean           @default(false)
  verified                Boolean           @default(false)
  ownerId                 String            @unique
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  subscriptionTier        SubscriptionTier  @default(FREE)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  owner                User                 @relation("BandOwner", fields: [ownerId], references: [id])
  tracks               Track[]
  releases             Release[]
  bandVotesReceived    BandVote[]           @relation("VotedBand")
  submissions          BandSubmission[]
  categorySubmissions  CategorySubmission[]
  aiPredictions        AIPrediction[]
  labelMandates        LabelBandMandate[]   @relation("BandMandate")
  awards               Award[]
  spotlights           Spotlight[]
  djFeedbackReceived   DJFeedback[]         @relation("BandFeedback")

  @@map("bands")
}

enum SubscriptionTier {
  FREE
  PRO
  PRO_PLUS
}

enum Genre {
  GOTH
  METAL
  DARK_ELECTRO
  POST_PUNK
  INDUSTRIAL
  DARKWAVE
  EBM
  SYMPHONIC_METAL
  AGGROTECH
  NEOFOLK
}

enum Tier {
  MICRO
  EMERGING
  ESTABLISHED
  INTERNATIONAL
  MACRO
}

model Track {
  id              String   @id @default(uuid())
  bandId          String
  title           String
  isrc            String?  @unique
  genre           Genre
  spotifyTrackId  String?
  itunesTrackId   String?
  coverArtUrl     String?
  submittedAt     DateTime @default(now())

  band             Band                  @relation(fields: [bandId], references: [id], onDelete: Cascade)
  fanVotes         FanVote[]
  djBallotEntries  DJBallotEntry[]
  streamingLinks   TrackStreamingLink[]
  transparencyLogs TransparencyLogEntry[]
  botAlerts        BotDetectionAlert[]
  djFeedback       DJFeedback[]

  @@index([bandId])
  @@map("tracks")
}

model TrackStreamingLink {
  id        String   @id @default(uuid())
  trackId   String
  platform  String
  url       String
  nativeUri String?
  fetchedAt DateTime @default(now())

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, platform])
  @@map("track_streaming_links")
}

model FanVote {
  id           String   @id @default(uuid())
  userId       String
  trackId      String?
  releaseId    String?
  categoryId   String?
  periodId     String
  votes        Int
  credits      Int      @default(0)
  creditsSpent Int
  weight       Float    @default(1.0)
  createdAt    DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id])
  track         Track?        @relation(fields: [trackId], references: [id])
  release       Release?      @relation(fields: [releaseId], references: [id])
  period        VotingPeriod  @relation(fields: [periodId], references: [id])

  @@index([trackId])
  @@index([releaseId])
  @@index([periodId])
  @@index([userId, periodId])
  @@map("fan_votes")
}

model DJBallot {
  id         String   @id @default(uuid())
  userId     String
  periodId   String
  genre      String?
  categoryId String?
  rankings   Json?
  createdAt  DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id])
  period  VotingPeriod    @relation(fields: [periodId], references: [id])
  entries DJBallotEntry[]

  @@unique([userId, periodId, categoryId])
  @@index([periodId])
  @@map("dj_ballots")
}

model DJBallotEntry {
  id       String @id @default(uuid())
  ballotId String
  trackId  String
  rank     Int

  ballot DJBallot @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  track  Track    @relation(fields: [trackId], references: [id])

  @@unique([ballotId, trackId])
  @@index([trackId])
  @@map("dj_ballot_entries")
}

model BandVote {
  id          String   @id @default(uuid())
  voterId     String
  votedBandId String
  periodId    String
  weight      Float    @default(1.0)
  rawWeight   Float    @default(1.0)
  cliqueCoeff Float    @default(1.0)
  createdAt   DateTime @default(now())

  voter     User         @relation("VoterBand", fields: [voterId], references: [id])
  votedBand Band         @relation("VotedBand", fields: [votedBandId], references: [id])
  period    VotingPeriod @relation(fields: [periodId], references: [id])

  @@unique([voterId, votedBandId, periodId])
  @@index([votedBandId])
  @@index([periodId])
  @@map("band_votes")
}

model VotingPeriod {
  id        String              @id @default(uuid())
  name      String?
  startDate DateTime
  endDate   DateTime
  isActive  Boolean             @default(false)
  status    VotingPeriodStatus  @default(OPEN)
  createdAt DateTime            @default(now())

  fanVotes       FanVote[]
  djBallots      DJBallot[]
  bandVotes      BandVote[]
  chartSnapshots ChartSnapshot[]
  chartResults   ChartResult[]

  @@map("voting_periods")
}

enum VotingPeriodStatus {
  OPEN
  CLOSED
  COMPUTING
  PUBLISHED
}

model ChartSnapshot {
  id            String   @id @default(uuid())
  periodId      String
  trackId       String
  genre         Genre
  fanScore      Float    @default(0)
  djScore       Float    @default(0)
  peerScore     Float    @default(0)
  combinedScore Float    @default(0)
  fanRank       Int?
  djRank        Int?
  peerRank      Int?
  combinedRank  Int?
  computedAt    DateTime @default(now())

  period VotingPeriod @relation(fields: [periodId], references: [id])

  @@unique([periodId, trackId])
  @@map("chart_snapshots")
}

// ─── Phase 2 Models ──────────────────────────────────────────────────────────

model Release {
  id           String       @id @default(uuid())
  bandId       String
  title        String
  type         ReleaseType  @default(SINGLE)
  releaseDate  DateTime
  trackCount   Int          @default(1)
  genres       String[]
  coverArtUrl  String?
  createdAt    DateTime     @default(now())

  band                 Band                 @relation(fields: [bandId], references: [id], onDelete: Cascade)
  streamingLinks       StreamingLink[]
  categorySubmissions  CategorySubmission[]
  fanVotes             FanVote[]
  chartResults         ChartResult[]

  @@index([bandId])
  @@map("releases")
}

enum ReleaseType {
  ALBUM
  EP
  SINGLE
}

model StreamingLink {
  id         String           @id @default(uuid())
  releaseId  String
  platform   StreamingPlatform
  url        String

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, platform])
  @@map("streaming_links")
}

enum StreamingPlatform {
  SPOTIFY
  APPLE_MUSIC
  YOUTUBE_MUSIC
  BANDCAMP
  TIDAL
  DEEZER
}

model CategorySubmission {
  id         String   @id @default(uuid())
  bandId     String
  releaseId  String
  categoryId String
  createdAt  DateTime @default(now())

  band    Band    @relation(fields: [bandId], references: [id])
  release Release @relation(fields: [releaseId], references: [id])

  @@unique([releaseId, categoryId])
  @@index([categoryId])
  @@map("category_submissions")
}

model ChartResult {
  id                String       @id @default(uuid())
  votingPeriodId    String
  categoryId        String
  releaseId         String
  rank              Int
  fanScore          Float        @default(0)
  djScore           Float        @default(0)
  combinedScore     Float        @default(0)
  appliedFanWeight  Float        @default(0.5)
  appliedDjWeight   Float        @default(0.5)
  totalFanVotes     Int          @default(0)
  totalDJBallots    Int          @default(0)
  quorumMet         Boolean      @default(false)
  createdAt         DateTime     @default(now())

  votingPeriod  VotingPeriod  @relation(fields: [votingPeriodId], references: [id])
  release       Release       @relation(fields: [releaseId], references: [id])

  @@unique([votingPeriodId, categoryId, releaseId])
  @@index([votingPeriodId, categoryId])
  @@map("chart_results")
}

model DJVerification {
  id           String                  @id @default(uuid())
  userId       String                  @unique
  djName       String
  realName     String
  status       DJVerificationStatus    @default(PENDING)
  eventHistory Json
  submittedAt  DateTime                @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?

  user User @relation(fields: [userId], references: [id])

  @@map("dj_verifications")
}

enum DJVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  metadata   Json
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}

model TransparencyLogEntry {
  id                String   @id @default(uuid())
  timestamp         DateTime @default(now())
  trackId           String
  userId            String
  voteType          VoteType
  rawVotes          Int
  creditsSpent      Int?
  weight            Float
  finalContribution Float
  reason            String?

  track Track @relation(fields: [trackId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([trackId])
  @@index([userId])
  @@map("transparency_log")
}

enum VoteType {
  FAN
  DJ
  PEER
}

model BotDetectionAlert {
  id              String      @id @default(uuid())
  timestamp       DateTime    @default(now())
  trackId         String
  bandId          String
  alertType       AlertType
  severity        Severity
  votesCount      Int
  timeWindow      Int
  suspiciousIPs   String[]
  newAccountRatio Float?
  status          AlertStatus @default(FLAGGED)
  reviewedById    String?
  reviewedAt      DateTime?

  track      Track @relation(fields: [trackId], references: [id])
  reviewedBy User? @relation("Reviewer", fields: [reviewedById], references: [id])

  @@index([trackId])
  @@index([reviewedById])
  @@map("bot_detection_alerts")
}

enum AlertType {
  VELOCITY
  NEW_ACCOUNTS
  IP_CLUSTER
  PATTERN
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum AlertStatus {
  FLAGGED
  REVIEWING
  CLEARED
  CONFIRMED_FRAUD
}

model BandSubmission {
  id             String   @id @default(uuid())
  bandId         String
  periodId       String
  freeCategory   Genre
  paidCategories Genre[]
  totalCost      Float    @default(0)
  submittedAt    DateTime @default(now())

  band Band @relation(fields: [bandId], references: [id])

  @@unique([bandId, periodId])
  @@map("band_submissions")
}

model AIPrediction {
  id              String   @id @default(uuid())
  bandId          String
  confidenceScore Float
  predictedTier   Tier
  voteVelocity    Float
  genreMomentum   Float
  streamGrowth    Float
  createdAt       DateTime @default(now())

  band Band @relation(fields: [bandId], references: [id])

  @@index([bandId])
  @@map("ai_predictions")
}

model LabelBandMandate {
  id        String        @id @default(uuid())
  labelId   String
  bandId    String
  status    MandateStatus @default(PENDING)
  grantedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime      @default(now())

  label User @relation("LabelMandate", fields: [labelId], references: [id])
  band  Band @relation("BandMandate", fields: [bandId], references: [id])

  @@unique([labelId, bandId])
  @@index([bandId])
  @@map("label_band_mandates")
}

enum MandateStatus {
  PENDING
  ACTIVE
  REVOKED
}

model Event {
  id          String   @id @default(uuid())
  name        String
  venue       String
  city        String
  country     String
  date        DateTime
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  intents EventIntent[]

  @@map("events")
}

model EventIntent {
  id      String @id @default(uuid())
  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_intents")
}

model Spotlight {
  id     String   @id @default(uuid())
  bandId String
  date   DateTime @default(now())

  band Band @relation(fields: [bandId], references: [id])

  @@index([bandId])
  @@map("spotlights")
}

model Award {
  id          String   @id @default(uuid())
  bandId      String?
  title       String
  description String
  awardType   String
  month       Int
  year        Int
  isAutomatic Boolean  @default(false)
  createdAt   DateTime @default(now())

  band Band? @relation(fields: [bandId], references: [id])

  @@index([bandId])
  @@map("awards")
}

model DJRankingScore {
  id                 String   @id @default(uuid())
  userId             String
  predictiveAccuracy Float    @default(0)
  participationRate  Float    @default(0)
  totalScore         Float    @default(0)
  computedAt         DateTime @default(now())

  @@index([userId])
  @@map("dj_ranking_scores")
}

model DJFeedback {
  id        String   @id @default(uuid())
  djId      String
  bandId    String
  trackId   String?
  message   String
  createdAt DateTime @default(now())

  dj    User  @relation("DJFeedbackGiver", fields: [djId], references: [id])
  band  Band  @relation("BandFeedback", fields: [bandId], references: [id])
  track Track? @relation(fields: [trackId], references: [id])

  @@index([djId])
  @@index([bandId])
  @@index([trackId])
  @@map("dj_feedback")
}

// ─── Achievement & Index System ───────────────────────────────────────────────

model AchievementDefinition {
  id          String          @id @default(uuid())
  slug        String          @unique
  pillar      AchievementPillar
  rarity      AchievementRarity @default(COMMON)
  titleDe     String
  titleEn     String
  descDe      String
  descEn      String
  iconKey     String          @default("award")
  requiresKyc Boolean         @default(false)
  isAutomatic Boolean         @default(true)
  createdAt   DateTime        @default(now())

  userAchievements UserAchievement[]

  @@map("achievement_definitions")
}

model UserAchievement {
  id              String   @id @default(uuid())
  userId          String
  achievementId   String
  grantedAt       DateTime @default(now())
  metadata        Json?

  achievement AchievementDefinition @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

enum AchievementPillar {
  FAN
  BAND
  DJ
  LABEL
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}
